@TodoApp.Api_HostAddress = http://localhost:5000
@token = {{signin.response.body.token}}
@refreshToken = {{signin.response.body.refreshToken}}

### Health
GET {{TodoApp.Api_HostAddress}}/api/health
Accept: application/json

### Sign up
POST {{TodoApp.Api_HostAddress}}/api/auth/signup
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123"
}

### Sign in
# @name signin
POST {{TodoApp.Api_HostAddress}}/api/auth/signin
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123"
}

### Refresh tokens
POST {{TodoApp.Api_HostAddress}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### List todos (unauthenticated — expect 401)
GET {{TodoApp.Api_HostAddress}}/api/todos
Accept: application/json

### List todos (authenticated)
GET {{TodoApp.Api_HostAddress}}/api/todos
Accept: application/json
Authorization: Bearer {{token}}

### Create todo
POST {{TodoApp.Api_HostAddress}}/api/todos
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Test todo"
}

### Update todo
PUT {{TodoApp.Api_HostAddress}}/api/todos/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Updated todo",
  "isCompleted": true
}

### Delete todo
DELETE {{TodoApp.Api_HostAddress}}/api/todos/1
Authorization: Bearer {{token}}
